{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hn2.github.io/uacp/schema/v1/kinds/pack",
  "title": "UACP Pack Body",
  "description": "Body schema for the pack artifact kind — a named, curated collection of related artifacts.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "maxLength": 512
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          }
        },
        "required": ["kind"],
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 50
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 10
    }
  },
  "required": ["title", "description", "artifact_refs"],
  "additionalProperties": false
}
