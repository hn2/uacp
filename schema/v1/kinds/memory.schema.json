{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hn2.github.io/uacp/schema/v1/kinds/memory",
  "title": "UACP Memory Body",
  "description": "Body schema for the memory artifact kind — a single persistent fact, preference, or piece of recalled context about a user.",
  "type": "object",
  "properties": {
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "category": {
      "type": "string",
      "pattern": "^(personal|professional|preference|health|relationship|financial|[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*)$"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 1
    },
    "source": {
      "type": "string",
      "maxLength": 256
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "required": ["content"],
  "additionalProperties": false
}
