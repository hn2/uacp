{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hn2.github.io/uacp/schema/v1/kinds/playbook",
  "title": "UACP Playbook Body",
  "description": "Body schema for the playbook artifact kind — a sequenced, multi-step workflow of instructions or actions.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "maxLength": 512
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "instruction": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "on_complete": {
            "type": "string",
            "maxLength": 512
          }
        },
        "required": ["step", "title", "instruction"],
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 50
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 10
    }
  },
  "required": ["title", "description", "steps"],
  "additionalProperties": false
}
