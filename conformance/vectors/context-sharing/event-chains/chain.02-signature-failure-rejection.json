{
  "id": "test_full_chain_rejected_on_signature_failure",
  "description": "Three-event chain — event 2 has invalid signature, chain must be rejected",
  "events": [
    {
      "event_id": "evt-001",
      "event_type": "conversation_created",
      "vector_clock": { "device-A": 1 },
      "signature": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    {
      "event_id": "evt-002",
      "event_type": "context_shared",
      "vector_clock": { "device-A": 2 },
      "signature": "not-a-valid-hex-signature"
    },
    {
      "event_id": "evt-003",
      "event_type": "context_received",
      "vector_clock": { "device-A": 3 },
      "signature": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    }
  ],
  "expected_causality": {
    "evt-002": "evt-001",
    "evt-003": "evt-002"
  },
  "expected_signatures": {
    "evt-001": "valid",
    "evt-002": "invalid",
    "evt-003": "valid"
  },
  "expected_outcome": "rejected"
}
